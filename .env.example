# Telegram Bot Token
BOT_TOKEN=your_telegram_bot_token_here

# Gemini API Key (required for Joe chat + image generation)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Joe chat model (fast recommended)
JOE_CHAT_MODEL=gemini-2.5-flash-lite
# Optional: request timeout in milliseconds
JOE_CHAT_TIMEOUT_MS=5000
# Optional: minimum delay between user messages in milliseconds
JOE_MIN_REPLY_INTERVAL_MS=350
# Optional: Joe output length limit
JOE_CHAT_MAX_TOKENS=260
# Optional: Joe creativity level
JOE_CHAT_TEMPERATURE=0.6
# Optional: per-user memory turns for Joe
JOE_MEMORY_TURNS=10
# Optional: limit Joe to specific Telegram user IDs (comma-separated). Leave empty to allow all.
JOE_ALLOWLIST_IDS=
# Optional: free fallback provider for Joe when Gemini fails
JOE_FREE_CHAT_ENDPOINT=https://text.pollinations.ai
JOE_FREE_CHAT_MODEL=openai
# Optional: free fallback timeout in milliseconds
JOE_FREE_TIMEOUT_MS=4200
# Optional: image generation model
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
# Optional: image generation timeout in milliseconds
GEMINI_IMAGE_TIMEOUT_MS=30000
# Optional: Hugging Face fallback token (used if Gemini image fails)
HF_TOKEN=your_huggingface_token_here
# Optional: HF model for fallback
HF_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
# Optional: Arabic->English translation model for prompts
HF_TRANSLATION_MODEL=Helsinki-NLP/opus-mt-ar-en
# Optional: translate Arabic image prompts before generation
HF_TRANSLATE_ARABIC_PROMPTS=true
# Optional: HF fallback timeout in milliseconds
HF_IMAGE_TIMEOUT_MS=30000
# Optional: enable free fallback if Gemini image fails (billing/quota/etc)
FREE_IMAGE_FALLBACK=true
# Optional: comma-separated free fallback endpoints (first working one is used)
FREE_IMAGE_ENDPOINTS=https://pollinations.ai/p,https://image.pollinations.ai/prompt

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Bot Owners (Telegram IDs)
BOT_OWNERS=123456789,987654321

# Automatic Ads (AdsGram for Telegram bots)
ADS_AUTO_ENABLED=false
ADS_PROVIDER=adsgram
ADSGRAM_TOKEN=your_adsgram_token_here
ADSGRAM_BLOCK_ID=your_adsgram_block_id_here
ADSGRAM_REWARD_SECRET=change_me_long_random_string
ADSGRAM_REWARD_COINS=5
# Show an ad every N normal private messages
ADS_FREQUENCY_MESSAGES=8
# Minimum delay between ad displays (seconds)
ADS_COOLDOWN_SECONDS=600
# Cache provider response for N seconds
ADS_CACHE_SECONDS=60

# Environment
NODE_ENV=development

# Proxy Settings (اختياري - Optional for bypassing network restrictions)
# استخدم واحد فقط من هذه الخيارات حسب نوع الـ Proxy المتاح
# HTTP/HTTPS Proxy
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# SOCKS Proxy (مع أو بدون مصادقة)
# SOCKS_PROXY=socks5://127.0.0.1:1080
# SOCKS_PROXY=socks5://username:password@proxy.example.com:1080


